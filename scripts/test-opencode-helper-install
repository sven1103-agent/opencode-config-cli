  root=$(prepare_release_root missing-entry)
  start_static_server "$root"

  home=$(make_home)
  output_file="$home/output.log"
  status=0
  run_installer_yes "$home" "/bin/zsh" "Linux" "$output_file" "$SERVER_API_BASE" "$SERVER_DOWNLOAD_BASE" || status=$?
  [ "$status" -ne 0 ] || fail "expected non-zero exit for missing checksum entry"
  [ ! -e "$home/bin/opencode-helper" ] || fail "did not expect installed helper on checksum entry failure"
  [ ! -e "$home/.zshrc" ] || fail "did not expect shell config changes on checksum entry failure"
  assert_text_contains "$(cat "$output_file")" 'checksum manifest missing bundle entry:'

  stop_static_server
}

