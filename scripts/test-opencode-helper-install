}

test_fish_config_creation() {
  root=$(prepare_release_root valid)
  start_static_server "$root"

  home=$(make_home)
  run_installer_yes "$home" "/usr/bin/fish" "Linux" "$home/output.log" "$SERVER_API_BASE" "$SERVER_DOWNLOAD_BASE"
  rc="$home/.config/fish/config.fish"
  [ -d "$home/.config/fish" ] || fail "expected fish config parent dir"
  assert_file_contains "$rc" 'set -gx PATH "'

  stop_static_server
}

test_missing_checksum_manifest_blocks_install() {
  root=$(prepare_release_root missing-manifest)
  start_static_server "$root"

  home=$(make_home)
  output_file="$home/output.log"
  status=0
  run_installer_yes "$home" "/bin/zsh" "Linux" "$output_file" "$SERVER_API_BASE" "$SERVER_DOWNLOAD_BASE" || status=$?
  [ "$status" -ne 0 ] || fail "expected non-zero exit for missing checksum manifest"
  [ ! -e "$home/bin/opencode-helper" ] || fail "did not expect installed helper on checksum manifest failure"
  [ ! -e "$home/.zshrc" ] || fail "did not expect shell config changes on checksum manifest failure"
  assert_text_contains "$(cat "$output_file")" 'failed to download checksum manifest:'

  stop_static_server
}

