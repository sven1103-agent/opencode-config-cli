#!/bin/sh

set -eu

BEGIN_SENTINEL="# opencode-helper: BEGIN managed PATH"
END_SENTINEL="# opencode-helper: END managed PATH"

RELEASE_REPO_DEFAULT="sven1103-agent/opencode-agents"
INSTALL_WORK_DIR=
FETCHED_HELPER_PATH=
FETCHED_BUNDLE_PATH=
FETCHED_RELEASE_TAG=

command_name() {
  basename "$0"
}

log() {
  printf '%s\n' "$*"
}

INFO_PREFIX='info:'
OK_PREFIX='ok:'
WARN_PREFIX='warn:'
ERROR_PREFIX='error:'

init_status_theme() {
  esc=$(printf '\033')

  if [ -t 1 ]; then
    INFO_PREFIX="${esc}[36minfo:${esc}[0m"
    OK_PREFIX="${esc}[32mok:${esc}[0m"
    WARN_PREFIX="${esc}[33mwarn:${esc}[0m"
  fi

  if [ -t 2 ]; then
    ERROR_PREFIX="${esc}[31merror:${esc}[0m"
  fi
}

say_info() {
  printf '%s %s\n' "$INFO_PREFIX" "$*"
}

say_ok() {
  printf '%s %s\n' "$OK_PREFIX" "$*"
}

say_warn() {
  printf '%s %s\n' "$WARN_PREFIX" "$*"
}

err() {
  printf '%s %s\n' "$ERROR_PREFIX" "$*" >&2
}

usage() {
  cat <<EOF
$(command_name) - install opencode-helper from an official release bundle and update PATH

Usage:
  $(command_name) [--yes] [--bin-dir PATH] [--version TAG]
  $(command_name) --help

Options:
  --yes           Non-interactive mode
  --bin-dir PATH  Install directory (default: ~/.local/bin)
  --version TAG   Install a specific release tag (default: latest)
  --help          Show this help
EOF
}

cleanup_install_work_dir() {
  if [ -n "${INSTALL_WORK_DIR:-}" ] && [ -d "$INSTALL_WORK_DIR" ]; then
    rm -rf "$INSTALL_WORK_DIR"
  fi
}

trap cleanup_install_work_dir EXIT INT TERM

sha256_file() {
  file=$1
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | awk '{print $1}'
  else
    shasum -a 256 "$file" | awk '{print $1}'
  fi
}

download_to_file() {
  url=$1
  dest=$2

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$dest"
    return $?
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -q -O "$dest" "$url"
    return $?
  fi

  err "missing downloader: require curl or wget"
  return 1
}

latest_release_tag() {
  api_base=$1
  out_file=$2

  latest_url=$(api_url_latest "$api_base")
  download_to_file "$latest_url" "$out_file" || {
    err "failed to fetch latest release metadata"
    return 1
  }

  tag=$(awk -F '"' '/"tag_name"[[:space:]]*:/ {print $4; exit}' "$out_file")
  if [ -z "$tag" ]; then
    err "latest release metadata missing tag_name"
    return 1
  fi

  LATEST_RELEASE_TAG=$tag
  return 0
}

api_url_latest() {
  api_base=$1
  case "$api_base" in
    */releases) printf '%s/latest\n' "$api_base" ;;
    *) printf '%s/releases/latest\n' "$api_base" ;;
  esac
}

api_url_tag() {
  api_base=$1
  tag=$2
  case "$api_base" in
    */releases) printf '%s/tags/%s\n' "$api_base" "$tag" ;;
    *) printf '%s/releases/tags/%s\n' "$api_base" "$tag" ;;
  esac
}

fetch_release_tag_metadata() {
  api_base=$1
  tag=$2
  out_file=$3

  url=$(api_url_tag "$api_base" "$tag")
  download_to_file "$url" "$out_file" || {
    err "release tag not found or not installable: $tag"
    return 1
  }

  found=$(awk -F '"' '/"tag_name"[[:space:]]*:/ {print $4; exit}' "$out_file")
  if [ -z "$found" ]; then
    err "release metadata missing tag_name for $tag"
    return 1
  fi
  if [ "$found" != "$tag" ]; then
    err "release metadata tag mismatch (wanted $tag, got $found)"
    return 1
  fi

  return 0
}

verify_bundle_checksum() {
  bundle_path=$1
  checksums_path=$2
  bundle_name=$3

  [ -f "$checksums_path" ] || {
    err "missing checksum manifest: $checksums_path"
    return 1
  }

  expected_sha=$(awk -v wanted="$bundle_name" '$2==wanted {print $1; found=1; exit} END {if (!found) exit 1}' "$checksums_path") || {
    err "checksum manifest missing bundle entry: $bundle_name"
    return 1
  }

  actual_sha=$(sha256_file "$bundle_path") || {
    err "failed to compute bundle checksum"
    return 1
  }

  if [ "$actual_sha" != "$expected_sha" ]; then
    err "bundle checksum mismatch for $bundle_name"
    return 1
  fi

  return 0
}

fetch_release_helper() {
  release_tag=$1
  release_repo=${OPENCODE_HELPER_RELEASE_REPO:-$RELEASE_REPO_DEFAULT}
  api_base=${OPENCODE_HELPER_RELEASE_API_BASE:-https://api.github.com/repos/$release_repo/releases}
  download_base=${OPENCODE_HELPER_RELEASE_DOWNLOAD_BASE:-https://github.com/$release_repo/releases/download}

  INSTALL_WORK_DIR=$(mktemp -d "${TMPDIR:-/tmp}/opencode-helper-install.XXXXXX") || {
    err "failed to create temporary workspace"
    return 1
  }

  # release_tag is resolved by the caller (interactive selection, explicit --version, or latest).

  bundle_root="opencode-helper-$release_tag"
  bundle_name="$bundle_root.tar.gz"
  checksums_name="$bundle_root-checksums.txt"
  bundle_url="$download_base/$release_tag/$bundle_name"
  checksums_url="$download_base/$release_tag/$checksums_name"
  bundle_path="$INSTALL_WORK_DIR/$bundle_name"
  checksums_path="$INSTALL_WORK_DIR/$checksums_name"
  extract_dir="$INSTALL_WORK_DIR/extracted"

  say_info "target release: $release_tag" >&2
  say_info "downloading release bundle" >&2

  download_to_file "$bundle_url" "$bundle_path" || {
    err "failed to download release bundle: $bundle_url"
    return 1
  }
  download_to_file "$checksums_url" "$checksums_path" || {
    err "failed to download checksum manifest: $checksums_url"
    return 1
  }

  verify_bundle_checksum "$bundle_path" "$checksums_path" "$bundle_name" || return 1
  say_ok "verified SHA-256 for $bundle_name" >&2

  mkdir -p "$extract_dir" || {
    err "failed to prepare extraction directory"
    return 1
  }
  tar -xzf "$bundle_path" -C "$extract_dir" || {
    err "failed to extract release bundle"
    return 1
  }

  helper_path="$extract_dir/$bundle_root/scripts/opencode-helper"
  if [ ! -f "$helper_path" ]; then
    err "release bundle missing helper executable"
    return 1
  fi
  manifest_path="$extract_dir/$bundle_root/release-manifest.json"
  if [ ! -f "$manifest_path" ]; then
    err "release bundle missing release-manifest.json"
    return 1
  fi

  FETCHED_HELPER_PATH=$helper_path
  FETCHED_BUNDLE_PATH="$extract_dir/$bundle_root"
  FETCHED_RELEASE_TAG=$release_tag
  return 0
}

install_home_default() {
  if [ -n "${OPENCODE_HELPER_INSTALL_HOME:-}" ]; then
    printf '%s\n' "$OPENCODE_HELPER_INSTALL_HOME"
    return 0
  fi

  if [ -n "${XDG_DATA_HOME:-}" ]; then
    printf '%s\n' "$XDG_DATA_HOME/opencode-helper"
    return 0
  fi

  printf '%s\n' "$HOME/.local/share/opencode-helper"
}

copy_release_bundle_to_install_home() {
  src_bundle=$1
  release_tag=$2
  install_home=$3

  release_parent="$install_home/releases"
  release_dir="$release_parent/$release_tag"

  [ -d "$src_bundle" ] || {
    err "source release bundle not found: $src_bundle"
    return 1
  }

  mkdir -p "$release_parent" || {
    err "failed to create install releases directory: $release_parent"
    return 1
  }

  rm -rf "$release_dir.tmp.$$"
  cp -R "$src_bundle" "$release_dir.tmp.$$" || {
    err "failed to stage release bundle copy"
    rm -rf "$release_dir.tmp.$$"
    return 1
  }

  rm -rf "$release_dir"
  mv "$release_dir.tmp.$$" "$release_dir" || {
    err "failed to install release bundle"
    return 1
  }

  printf '%s\n' "$release_dir"
}

activate_release_current_symlink() {
  install_home=$1
  release_dir=$2

  current_path="$install_home/current"
  current_tmp="$install_home/current.tmp.$$"

  ln -s "$release_dir" "$current_tmp" || {
    err "failed to create staged current symlink"
    return 1
  }
  mv -f "$current_tmp" "$current_path" || {
    err "failed to activate current release symlink"
    rm -f "$current_tmp"
    return 1
  }

  return 0
}

write_launcher_script() {
  bindir=$1
  install_home=$2
  dest="$bindir/opencode-helper"

  if [ ! -d "$bindir" ]; then
    if is_privileged_dir "$bindir"; then
      sudo mkdir -p "$bindir"
    else
      mkdir -p "$bindir"
    fi
  fi

  launcher_tmp=$(mktemp "${TMPDIR:-/tmp}/opencode-helper-launcher.XXXXXX") || {
    err "failed to prepare launcher"
    return 1
  }

  cat >"$launcher_tmp" <<EOF
#!/bin/sh

set -eu

INSTALL_HOME="$(printf '%s' "$install_home")"
HELPER="\$INSTALL_HOME/current/scripts/opencode-helper"

if [ ! -x "\$HELPER" ]; then
  printf 'error: installed helper missing or not executable: %s\n' "\$HELPER" >&2
  exit 1
fi

exec "\$HELPER" "\$@"
EOF

  chmod +x "$launcher_tmp"

  if is_privileged_dir "$bindir"; then
    say_info "privileged install location detected; requesting sudo for binary write"
    sudo cp "$launcher_tmp" "$dest"
    sudo chmod +x "$dest"
  else
    cp "$launcher_tmp" "$dest"
    chmod +x "$dest"
  fi

  rm -f "$launcher_tmp"
}

is_absolute_path() {
  case "$1" in
    /*) return 0 ;;
    *) return 1 ;;
  esac
}

expand_home_path() {
  path=$1
  case "$path" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${path#\~/}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

is_privileged_dir() {
  dir=$1
  case "$dir" in
    /usr/local|/usr/local/*|/opt/homebrew|/opt/homebrew/*|/usr/bin|/usr/bin/*|/bin|/bin/*|/sbin|/sbin/*|/opt|/opt/*)
      return 0
      ;;
  esac
  if [ -d "$dir" ]; then
    [ -w "$dir" ] || return 0
    return 1
  fi
  parent=$(dirname "$dir")
  while [ ! -d "$parent" ]; do
    next=$(dirname "$parent")
    [ "$next" = "$parent" ] && break
    parent=$next
  done
  [ -w "$parent" ] || return 0
  return 1
}

detect_shell_name() {
  shell_path=${SHELL:-}

  if [ -z "$shell_path" ]; then
    err "SHELL is not set; cannot determine shell config file"
    return 1
  fi

  shell_name=$(basename "$shell_path")

  case "$shell_name" in
    zsh|fish|bash)
      printf '%s\n' "$shell_name"
      return 0
      ;;
    *)
      err "unsupported SHELL value: $shell_path"
      return 1
      ;;
  esac
}

select_rc_file() {
  shell_name=$1

  case "$shell_name" in
    zsh)
      printf '%s/.zshrc\n' "$HOME"
      return 0
      ;;
    fish)
      printf '%s/.config/fish/config.fish\n' "$HOME"
      return 0
      ;;
    bash)
      os_name=$(uname -s 2>/dev/null || printf 'unknown')
      if [ "$os_name" = "Darwin" ]; then
        if [ -f "$HOME/.bash_profile" ]; then
          printf '%s/.bash_profile\n' "$HOME"
        elif [ -f "$HOME/.bashrc" ]; then
          printf '%s/.bashrc\n' "$HOME"
        else
          printf '%s/.bash_profile\n' "$HOME"
        fi
      else
        if [ -f "$HOME/.bashrc" ]; then
          printf '%s/.bashrc\n' "$HOME"
        elif [ -f "$HOME/.bash_profile" ]; then
          printf '%s/.bash_profile\n' "$HOME"
        else
          printf '%s/.bashrc\n' "$HOME"
        fi
      fi
      return 0
      ;;
  esac
}

build_managed_block() {
  bindir=$1
  shell_name=$2

  case "$shell_name" in
    fish)
      path_line="set -gx PATH \"$bindir\" \$PATH"
      ;;
    *)
      path_line="export PATH=\"$bindir:\$PATH\""
      ;;
  esac

  cat <<EOF
$BEGIN_SENTINEL
$path_line
$END_SENTINEL
EOF
}

update_rc_file() {
  rc_file=$1
  bindir=$2
  shell_name=$3
  managed_block=$(build_managed_block "$bindir" "$shell_name")

  case "$shell_name" in
    fish)
      path_line="set -gx PATH \"$bindir\" \$PATH"
      ;;
    *)
      path_line="export PATH=\"$bindir:\$PATH\""
      ;;
  esac

  rc_dir=$(dirname "$rc_file")
  mkdir -p "$rc_dir"
  [ -f "$rc_file" ] || : > "$rc_file"

  begin_count=$(awk -v b="$BEGIN_SENTINEL" '$0==b {count++} END {print count+0}' "$rc_file")
  end_count=$(awk -v e="$END_SENTINEL" '$0==e {count++} END {print count+0}' "$rc_file")

  if [ "$begin_count" -gt 1 ] || [ "$end_count" -gt 1 ]; then
    err "multiple managed PATH blocks found in $rc_file"
    return 1
  fi

  if [ "$begin_count" -ne "$end_count" ]; then
    err "managed PATH block sentinel mismatch in $rc_file"
    return 1
  fi

  tmp_file="$rc_file.tmp.$$"

  if [ "$begin_count" -eq 1 ]; then
    awk -v begin="$BEGIN_SENTINEL" -v end="$END_SENTINEL" -v line="$path_line" '
      $0==begin {
        print begin
        print line
        print end
        in_block=1
        next
      }
      in_block && $0==end {in_block=0; next}
      !in_block {print}
    ' "$rc_file" > "$tmp_file"
  else
    cp "$rc_file" "$tmp_file"
    if [ -s "$tmp_file" ]; then
      printf '\n%s\n' "$managed_block" >> "$tmp_file"
    else
      printf '%s\n' "$managed_block" >> "$tmp_file"
    fi
  fi

  mv "$tmp_file" "$rc_file"

  block_bindir_count=$(awk -v begin="$BEGIN_SENTINEL" -v end="$END_SENTINEL" -v d="$bindir" '
    $0==begin {in_block=1; next}
    $0==end {in_block=0; next}
    in_block {
      line=$0
      while (index(line, d) > 0) {
        count++
        line=substr(line, index(line, d) + length(d))
      }
    }
    END {print count+0}
  ' "$rc_file")

  if [ "$block_bindir_count" -ne 1 ]; then
    err "managed block must contain bin dir exactly once"
    return 1
  fi

  return 0
}

copy_helper_binary() {
  src=$1
  bindir=$2
  install_home=$3

  if [ ! -f "$src" ]; then
    err "source helper not found: $src"
    return 1
  fi

  write_launcher_script "$bindir" "$install_home"
}

is_interactive_mode() {
  if [ "$ASSUME_YES" -eq 1 ]; then
    return 1
  fi
  [ -t 0 ]
}

can_prompt_via_tty() {
  [ -r /dev/tty ] && [ -w /dev/tty ]
}

is_bin_dir_inconvenient() {
  dir=$1

  if is_privileged_dir "$dir"; then
    return 0
  fi

  if [ -d "$dir" ]; then
    [ -w "$dir" ] || return 0
    return 1
  fi

  parent=$(dirname "$dir")
  while [ ! -d "$parent" ]; do
    next=$(dirname "$parent")
    [ "$next" = "$parent" ] && break
    parent=$next
  done

  [ -w "$parent" ] || return 0
  return 1
}

prompt_bin_dir_if_needed() {
  if [ "$BIN_DIR_WAS_SET" -eq 1 ]; then
    return 0
  fi
  if ! is_interactive_mode; then
    return 0
  fi
  if ! is_bin_dir_inconvenient "$BIN_DIR"; then
    return 0
  fi

  if ! can_prompt_via_tty; then
    say_warn "default bin dir appears inconvenient but /dev/tty is unavailable; using $BIN_DIR"
    return 0
  fi

  printf 'Install directory [%s]: ' "$BIN_DIR" >/dev/tty
  if IFS= read -r choice </dev/tty; then
    if [ -n "$choice" ]; then
      BIN_DIR=$choice
    fi
  fi
}

manual_path_instruction() {
  bindir=$1
  printf 'add %s to PATH manually (for example: export PATH="%s:$PATH")\n' "$bindir" "$bindir"
}

init_status_theme

ASSUME_YES=0
BIN_DIR="$HOME/.local/bin"
REQUESTED_VERSION=
BIN_DIR_WAS_SET=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes)
      ASSUME_YES=1
      ;;
    --bin-dir)
      shift
      [ "$#" -gt 0 ] || { err "--bin-dir requires a path"; exit 1; }
      BIN_DIR=$1
      BIN_DIR_WAS_SET=1
      ;;
    --version)
      shift
      [ "$#" -gt 0 ] || { err "--version requires a tag"; exit 1; }
      REQUESTED_VERSION=$1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      err "unknown option: $1"
      usage >&2
      exit 1
      ;;
  esac
  shift
done

BIN_DIR=$(expand_home_path "$BIN_DIR")
prompt_bin_dir_if_needed
BIN_DIR=$(expand_home_path "$BIN_DIR")
if ! is_absolute_path "$BIN_DIR"; then
  err "--bin-dir must resolve to an absolute path"
  exit 1
fi

say_info "install bin dir: $BIN_DIR"

release_repo=${OPENCODE_HELPER_RELEASE_REPO:-$RELEASE_REPO_DEFAULT}
api_base=${OPENCODE_HELPER_RELEASE_API_BASE:-https://api.github.com/repos/$release_repo/releases}

RELEASE_TAG=
if [ -n "${REQUESTED_VERSION:-}" ]; then
  tmp_meta=$(mktemp "${TMPDIR:-/tmp}/opencode-helper-install.tag.XXXXXX.json") || {
    err "failed to create temporary workspace"
    exit 1
  }
  fetch_release_tag_metadata "$api_base" "$REQUESTED_VERSION" "$tmp_meta" || {
    rm -f "$tmp_meta" || true
    exit 1
  }
  rm -f "$tmp_meta" || true
  RELEASE_TAG=$REQUESTED_VERSION
else
  tmp_latest=$(mktemp "${TMPDIR:-/tmp}/opencode-helper-install.latest.XXXXXX.json") || {
    err "failed to create temporary workspace"
    exit 1
  }
  latest_release_tag "$api_base" "$tmp_latest" || {
    rm -f "$tmp_latest" || true
    exit 1
  }
  rm -f "$tmp_latest" || true
  RELEASE_TAG=$LATEST_RELEASE_TAG
fi

fetch_release_helper "$RELEASE_TAG" || exit 1
SOURCE_HELPER=$FETCHED_HELPER_PATH

SOURCE_BUNDLE=$FETCHED_BUNDLE_PATH
INSTALL_HOME=$(expand_home_path "$(install_home_default)")
if ! is_absolute_path "$INSTALL_HOME"; then
  err "install home must resolve to an absolute path: $INSTALL_HOME"
  exit 1
fi
say_info "install home: $INSTALL_HOME"

RELEASE_DIR=$(copy_release_bundle_to_install_home "$SOURCE_BUNDLE" "$RELEASE_TAG" "$INSTALL_HOME") || exit 1
copy_helper_binary "$SOURCE_HELPER" "$BIN_DIR" "$INSTALL_HOME" || exit 1
activate_release_current_symlink "$INSTALL_HOME" "$RELEASE_DIR" || exit 1

PATH_UPDATED=0
if SHELL_NAME=$(detect_shell_name 2>/dev/null) && [ -n "$SHELL_NAME" ]; then
  RC_FILE=$(select_rc_file "$SHELL_NAME") || {
    err "failed to determine shell config file"
    exit 1
  }
  say_info "shell config file: $RC_FILE"
  update_rc_file "$RC_FILE" "$BIN_DIR" "$SHELL_NAME" || exit 1
  PATH_UPDATED=1
else
  if is_interactive_mode; then
    detect_shell_name || exit 1
  fi
  say_warn "unable to detect a supported shell; skipping PATH config update"
  say_warn "$(manual_path_instruction "$BIN_DIR")"
fi

say_ok "installed opencode-helper to $BIN_DIR/opencode-helper"
say_ok "active installed release: $RELEASE_TAG"
if [ "$PATH_UPDATED" -eq 1 ]; then
  say_ok "updated PATH block in $RC_FILE"
else
  say_warn "installation completed without PATH updates"
fi
